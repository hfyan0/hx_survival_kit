#!/bin/bash

tmpfile1=$(mktemp)
tmpfile2=$(mktemp)
tmpfile3=$(mktemp)

# stdin
cat - > $tmpfile1

# get number of indentation
indentation=$(($(cat $tmpfile1 | head -n 1 | wc -c) - $(cat $tmpfile1 | head -n 1 | sed 's/^\s\+//' | wc -c)))

# remove tab
# convert o bullets to -
cat $tmpfile1 | tr '\t' ' ' | sed -e 's/^o[ \t]/- /' > $tmpfile2

# check if the lines are preceded by pipes
if [[ $(cat $tmpfile2 | head -n 1 | sed 's/^\s\+//' | cut -c1) == "|" ]]
then
    has_pipe="Y"
else
    has_pipe="N"
fi

# remove the pipes if they are present
cat $tmpfile2 | sed 's/^\s\+//' > $tmpfile1
if [[ $has_pipe == "Y" ]]
then
    cat $tmpfile1 | sed -e 's/^| //' | sed -e 's/^|//' > $tmpfile2
else
    cat $tmpfile1 > $tmpfile2
fi

cat $tmpfile2 \
    | sed -e 's/\s\+$//' \
    | sed ':a;N;$!ba;s/\n\n/TWOLINES/g' \
    | sed ':a;N;$!ba;s/\n-/ONELINE-/g' \
    | sed ':a;N;$!ba;s/\n>/ONELINE>/g' \
    | sed ':a;N;$!ba;s/\nâ€¢/ONELINEâ€¢/g' \
    | sed ':a;N;$!ba;s/\n0\./ONELINE0\./g' \
    | sed ':a;N;$!ba;s/\n1\./ONELINE1\./g' \
    | sed ':a;N;$!ba;s/\n2\./ONELINE2\./g' \
    | sed ':a;N;$!ba;s/\n3\./ONELINE3\./g' \
    | sed ':a;N;$!ba;s/\n4\./ONELINE4\./g' \
    | sed ':a;N;$!ba;s/\n5\./ONELINE5\./g' \
    | sed ':a;N;$!ba;s/\n6\./ONELINE6\./g' \
    | sed ':a;N;$!ba;s/\n7\./ONELINE7\./g' \
    | sed ':a;N;$!ba;s/\n8\./ONELINE8\./g' \
    | sed ':a;N;$!ba;s/\n9\./ONELINE9\./g' \
    | sed ':a;N;$!ba;s/\n0)/ONELINE0)/g' \
    | sed ':a;N;$!ba;s/\n1)/ONELINE1)/g' \
    | sed ':a;N;$!ba;s/\n2)/ONELINE2)/g' \
    | sed ':a;N;$!ba;s/\n3)/ONELINE3)/g' \
    | sed ':a;N;$!ba;s/\n4)/ONELINE4)/g' \
    | sed ':a;N;$!ba;s/\n5)/ONELINE5)/g' \
    | sed ':a;N;$!ba;s/\n6)/ONELINE6)/g' \
    | sed ':a;N;$!ba;s/\n7)/ONELINE7)/g' \
    | sed ':a;N;$!ba;s/\n8)/ONELINE8)/g' \
    | sed ':a;N;$!ba;s/\n9)/ONELINE9)/g' \
    | tr '\n' ' ' \
    | sed 's/TWOLINES/\n\n/g' \
    | sed 's/ONELINE/\n/g' \
    | sed 's/\([.!?]\)\s\+\([a-z]\)/\1 \u\2/g' \
    | sed 's/^\([-â€¢>]\) \([a-z]\)/\1 \u\2/g' \
    | fold -s \
> $tmpfile3

# remove multiple lines
# insert EOL EOL back
# insert EOL back
# capitalize first char in each sentence
# capitalize first char on bullet point

# indenting bullet points
if [[ -n $(cat $tmpfile3 | grep "^- \[ \]") ]]
then
    # checkbox "- [ ]"
    cat $tmpfile3 \
        | awk '{if (!/^- \[ \] /) $0 = "      " $0}1'
    > $tmpfile1
elif [[ -n $(cat $tmpfile3 | grep "^- ") ]]
then
    # bullet point "- "
    cat $tmpfile3 \
        | sed -E 's/^([^-]|-[^ ])/  \0/' \
    > $tmpfile1
elif [[ -n $(cat $tmpfile3 | grep "^â€¢ ") ]]
then
    # bullet point "â€¢ "
    cat $tmpfile3 \
        | sed -E 's/^([^â€¢]|â€¢[^ ])/  \0/' \
    > $tmpfile1
elif [[ -n $(cat $tmpfile3 | grep "^> ") ]]
then
    # bullet point "> "
    cat $tmpfile3 \
        | sed -E 's/^([^>]|>[^ ])/  \0/' \
    > $tmpfile1
else
    cat $tmpfile3 > $tmpfile1
fi

# indenting numbering
if [[ -n $(cat $tmpfile1 | grep -E "^1\. |^1\.	|^1\) |^1\)	") ]]
then
    cat $tmpfile1 \
        | awk '{if (!/^[0-9]+[\.\)] /) $0 = "   " $0}1' \
    > $tmpfile2
else
    cat $tmpfile1 > $tmpfile2
fi

# add back preceding pipes
if [[ $has_pipe == "Y" ]]
then
    cat $tmpfile2 | sed -e 's/^/| /' > $tmpfile3
else
    cat $tmpfile2 > $tmpfile3
fi
cat $tmpfile3 | sed 's/\s\+$//' > $tmpfile1

# add back indentation
sed -i "s/^/$(printf '%*s' $indentation)/" $tmpfile1
cat $tmpfile1

rm -f $tmpfile1 $tmpfile2 $tmpfile3
